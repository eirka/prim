{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": ["src/**/*.ts", "src/**/*.vue"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "html": {
    "experimentalFullSupportEnabled": true
  },
  "linter": {
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "error"
      },
      "suspicious": {
        "noAssignInExpressions": "off"
      },
      "a11y": {
        "useAltText": "error",
        "useAnchorContent": "error",
        "useButtonType": "error",
        "useMediaCaption": "error"
      }
    }
  }
}

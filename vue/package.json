{
  "name": "prim",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "styles": "sass --no-source-map --style=compressed ${STYLES_DIR:-../../chounyuu/chounyuu-styles}/sass/:${STYLES_DIR:-../../chounyuu/chounyuu-styles}/css/",
    "styles:default": "cp ${STYLES_DIR:-../../chounyuu/chounyuu-styles}/css/meta.css public/meta.css",
    "styles:all": "npm run styles && npm run styles:default",
    "test": "vitest run",
    "type-check": "vue-tsc --noEmit",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --fix src/",
    "check": "biome check --enforce-assist=true src/",
    "check:fix": "biome check --enforce-assist=true --fix src/"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.3.0",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "jsdom": "^28.1.0",
    "sass": "^1.70.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
